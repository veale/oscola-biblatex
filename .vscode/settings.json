{
  // Use latexmk driven by .latexmkrc.  The rc file sets LuaLaTeX as the
  // engine, routes all output into build/, and ensures the local package
  // files shadow any system-installed oscola.
  "latex-workshop.latex.tools": [
    {
      "name": "latexmk",
      "command": "latexmk",
      "args": ["%DOC%"]
    }
  ],

  "latex-workshop.latex.recipes": [
    {
      "name": "latexmk (oscola-dev)",
      "tools": ["latexmk"]
    }
  ],

  // Make this recipe run automatically on save.
  "latex-workshop.latex.recipe.default": "latexmk (oscola-dev)",

  // Tell LaTeX Workshop where to find the PDF and synctex file.
  "latex-workshop.latex.outDir": "%DIR%/build"
}
